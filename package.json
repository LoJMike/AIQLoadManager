{
  "name": "ai-queue-manager",
  "version": "1.3.0",
  "description": "Cross-platform AI prompt queue manager — Claude, GPT, Gemini, Groq, DeepSeek, Mistral, Grok",
  "main": "src/main/index-v2.js",
  "scripts": {
    "start": "node_modules/.bin/electron .",
    "start:win": "set NODE_ENV=development&& node_modules\\.bin\\electron .",
    "dev:renderer": "node_modules/.bin/vite --port 3000",
    "dev:win": "node_modules/.bin/concurrently \"npm run dev:renderer\" \"node_modules/.bin/wait-on http://localhost:3000 && npm run start:win\"",
    "build": "node_modules/.bin/vite build && node_modules/.bin/electron-builder",
    "build:win": "node_modules/.bin/vite build && node_modules/.bin/electron-builder --win",
    "build:mac": "node_modules/.bin/vite build && node_modules/.bin/electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.97.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "glob": "11.0.2",
    "rimraf": "^6.0.0",
    "tar": "^7.0.0",
    "inflight": "npm:lru-cache@^11.0.0",
    "npmlog": "^7.0.0",
    "gauge": "^5.0.0",
    "are-we-there-yet": "^4.0.0",
    "node-domexception": "npm:undici@^7.0.0",
    "node-fetch": "^3.0.0",
    "@npmcli/move-file": "npm:@npmcli/fs@^4.0.0",
    "boolean": "file:stubs/boolean"
  },
  "build": {
    "appId": "com.aiqueuemanager.app",
    "productName": "AI Queue Manager",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "src/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}