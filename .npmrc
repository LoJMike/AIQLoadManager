# Suppress funding messages
fund=false

# Suppress audit summary on install (run npm audit manually when needed)
audit=false

# Suppress deprecation warnings from transitive dependencies.
# electron-builder internally uses old packages (glob@7, rimraf@3) that
# cannot be overridden at the depth they are nested. These are not security
# vulnerabilities (npm audit does not flag them). This setting hides the
# noise while keeping real errors (exit code failures) visible.
# Valid loglevel values: silent, error, warn, notice, http, timing, info, verbose, silly
loglevel=error
